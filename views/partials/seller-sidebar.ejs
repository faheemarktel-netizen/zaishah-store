<div class="sidebar">
  <div class="sidebar-header">
    <h3>🏪 <%= typeof store !== 'undefined' && store ? store.name : 'My Store' %></h3>
    <p><%= typeof store !== 'undefined' && store && store.approved ? '✅ Approved' : '⏳ Pending Approval' %></p>
  </div>
  <nav class="sidebar-nav">
    <a href="/seller/dashboard" class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">📊 Dashboard</a>
    <a href="/seller/products" class="<%= typeof active !== 'undefined' && active === 'products' ? 'active' : '' %>">🏷️ Products</a>
    <a href="/seller/orders" class="<%= typeof active !== 'undefined' && active === 'orders' ? 'active' : '' %>">📋 Orders</a>
    <a href="/seller/earnings" class="<%= typeof active !== 'undefined' && active === 'earnings' ? 'active' : '' %>">💰 Earnings</a>
    <a href="/store/<%= typeof store !== 'undefined' && store ? store.slug : '#' %>">👁️ View Store</a>
    <a href="/">🏠 Back to Store</a>
  </nav>
</div>

<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <h2 style="margin-bottom: 1.5rem;">🛒 Shopping Cart</h2>

    <% if (items && items.length > 0) { %>
    <div class="cart-layout">
      <div class="card">
        <div class="card-body" style="padding: 0;">
          <% items.forEach(item => { %>
            <div class="cart-item" id="cart-item-<%= item.id %>">
              <div class="cart-item-img">
                <% const imgs = JSON.parse(item.images || '[]'); %>
                <% if (imgs.length > 0) { %>
                  <img src="<%= imgs[0] %>" alt="<%= item.name %>" style="width:100%;height:100%;object-fit:cover;">
                <% } else { %>
                  🛍️
                <% } %>
              </div>
              <div class="cart-item-info">
                <h3><a href="/product/<%= item.product_id %>"><%= item.name %></a></h3>
                <div class="store"><a href="/store/<%= item.store_slug %>"><%= item.store_name %></a></div>
                <div class="price">PKR <%= item.price.toLocaleString() %></div>
                <div class="d-flex align-center gap-1" style="margin-top: 0.5rem;">
                  <div class="quantity-control" style="margin-bottom: 0;">
                    <button type="button" onclick="updateQty(<%= item.id %>, <%= item.quantity - 1 %>)">−</button>
                    <input type="number" value="<%= item.quantity %>" readonly style="width: 50px;">
                    <button type="button" onclick="updateQty(<%= item.id %>, <%= item.quantity + 1 %>)">+</button>
                  </div>
                  <button class="btn btn-danger btn-sm" onclick="removeItem(<%= item.id %>)">Remove</button>
                </div>
              </div>
              <div style="text-align: right; font-weight: 700; color: var(--primary); min-width: 120px;">
                PKR <%= (item.price * item.quantity).toLocaleString() %>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="cart-summary">
        <h3>Order Summary</h3>
        <div class="summary-row">
          <span>Subtotal (<%= items.length %> items)</span>
          <span>PKR <%= total.toLocaleString() %></span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span style="color: var(--success);">Free</span>
        </div>
        <div class="summary-row total">
          <span>Total</span>
          <span>PKR <%= total.toLocaleString() %></span>
        </div>
        <div class="no-cod-notice" style="margin: 1rem 0; font-size: 0.8rem;">
          <span class="icon">💳</span>
          <div><strong>Card Only</strong> — No COD</div>
        </div>
        <a href="/checkout" class="btn btn-primary btn-block btn-lg">Proceed to Checkout</a>
        <a href="/search" class="btn btn-outline btn-block" style="margin-top: 0.5rem;">Continue Shopping</a>
      </div>
    </div>
    <% } else { %>
      <div class="empty-state">
        <div class="icon">🛒</div>
        <h3>Your cart is empty</h3>
        <p>Start adding products to your cart!</p>
        <a href="/search" class="btn btn-primary">Browse Products</a>
      </div>
    <% } %>
  </div>
</div>

<script>
function updateQty(itemId, quantity) {
  fetch('/cart/update', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ itemId, quantity })
  }).then(() => window.location.reload());
}

function removeItem(itemId) {
  fetch('/cart/remove', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ itemId })
  }).then(() => window.location.reload());
}
</script>
<%- include('../partials/footer') %>

<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div style="text-align: center; padding: 3rem; background: white; border-radius: 12px; box-shadow: var(--shadow);">
      <div style="font-size: 4rem; margin-bottom: 1rem;">✅</div>
      <h1 style="color: var(--primary); margin-bottom: 0.5rem;">Order Confirmed!</h1>
      <p style="color: var(--text-light); margin-bottom: 2rem;">Thank you for your purchase. Your order has been placed successfully.</p>
      
      <% if (orders && orders.length > 0) { %>
        <div style="max-width: 600px; margin: 0 auto 2rem;">
          <% orders.forEach(order => { %>
            <div style="display: flex; justify-content: space-between; padding: 0.75rem; background: var(--bg); border-radius: 8px; margin-bottom: 0.5rem;">
              <span>Order #<%= order.id %> — <%= order.store_name %></span>
              <span style="font-weight: 700; color: var(--primary);">PKR <%= order.total.toLocaleString() %></span>
            </div>
          <% }); %>
        </div>
      <% } %>

      <div class="d-flex gap-1" style="justify-content: center;">
        <a href="/checkout/orders" class="btn btn-primary">View My Orders</a>
        <a href="/" class="btn btn-outline">Continue Shopping</a>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

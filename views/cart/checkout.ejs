<%- include('../partials/header') %>

<div class="container" style="max-width: 800px; margin: 2rem auto; padding: 0 1rem;">
  <h2 style="margin-bottom: 1.5rem;">💳 Checkout</h2>

  <div class="card mb-2">
    <div class="card-header">Order Summary</div>
    <div class="card-body" style="padding: 0;">
      <table>
        <thead>
          <tr><th>Product</th><th>Store</th><th>Qty</th><th>Price</th><th>Subtotal</th></tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td><%= item.name %></td>
              <td><%= item.store_name %></td>
              <td><%= item.quantity %></td>
              <td>PKR <%= item.price.toLocaleString() %></td>
              <td>PKR <%= (item.price * item.quantity).toLocaleString() %></td>
            </tr>
          <% }); %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="4" style="text-align: right; font-weight: 700;">Total:</td>
            <td style="font-weight: 700; color: var(--gold-dark);">PKR <%= total.toLocaleString() %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="card mb-2">
    <div class="card-header">📍 Shipping Address</div>
    <div class="card-body">
      <textarea id="shipping-address" class="form-control" rows="3" placeholder="Enter your full shipping address..." style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: var(--radius-sm); font-family: inherit; resize: vertical;"></textarea>
    </div>
  </div>

  <div class="card mb-2">
    <div class="card-header">💳 Payment Method</div>
    <div class="card-body" style="text-align: center;">
      <p style="margin-bottom: 1rem; color: var(--text-light);">Secure payment powered by <strong>Safepay</strong></p>
      <p style="margin-bottom: 1.5rem; font-size: 0.9rem; color: var(--text-muted);">Accepts Visa, Mastercard & local debit/credit cards</p>
      
      <button id="pay-btn" onclick="initiatePayment()" class="btn btn-gold btn-lg" style="min-width: 250px;">
        Pay PKR <%= total.toLocaleString() %> →
      </button>

      <div id="payment-error" style="display: none; margin-top: 1rem; color: var(--danger); font-size: 0.9rem;"></div>
      <div id="payment-loading" style="display: none; margin-top: 1rem; color: var(--text-light);">
        ⏳ Preparing secure payment...
      </div>
    </div>
  </div>

  <p style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-top: 1rem;">
    🔒 Your payment is secure and encrypted. No card details are stored on our servers.
  </p>
</div>

<script>
function initiatePayment() {
  const btn = document.getElementById('pay-btn');
  const loading = document.getElementById('payment-loading');
  const errorDiv = document.getElementById('payment-error');
  const address = document.getElementById('shipping-address').value;

  if (!address.trim()) {
    errorDiv.textContent = 'Please enter your shipping address.';
    errorDiv.style.display = 'block';
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Processing...';
  loading.style.display = 'block';
  errorDiv.style.display = 'none';

  fetch('/checkout/pay', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ shippingAddress: address })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success && data.checkoutUrl) {
      window.location.href = data.checkoutUrl;
    } else {
      throw new Error(data.error || 'Payment failed');
    }
  })
  .catch(err => {
    btn.disabled = false;
    btn.textContent = 'Pay PKR <%= total.toLocaleString() %> →';
    loading.style.display = 'none';
    errorDiv.textContent = err.message || 'Payment failed. Please try again.';
    errorDiv.style.display = 'block';
  });
}
</script>

<%- include('../partials/footer') %>

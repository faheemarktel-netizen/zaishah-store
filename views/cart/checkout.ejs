<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <h2 style="margin-bottom: 1.5rem;">💳 Checkout</h2>

    <div class="no-cod-notice">
      <span class="icon">💳</span>
      <div><strong>Card Payment Only</strong> — We accept Visa, Mastercard, and other major cards via Stripe. No Cash on Delivery.</div>
    </div>

    <div class="cart-layout">
      <div>
        <div class="card mb-2">
          <div class="card-header">📦 Shipping Address</div>
          <div class="card-body">
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" id="fullName" class="form-control" value="<%= user.name %>" required>
            </div>
            <div class="form-group">
              <label>Address</label>
              <textarea id="address" class="form-control" rows="3" placeholder="Street address, city, province..." required></textarea>
            </div>
            <div class="form-group">
              <label>Phone Number</label>
              <input type="tel" id="phone" class="form-control" placeholder="03XX-XXXXXXX" required>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">💳 Card Payment</div>
          <div class="card-body">
            <div id="card-element" style="padding: 1rem; border: 2px solid var(--border); border-radius: var(--radius-sm); margin-bottom: 1rem;">
              <!-- Stripe card element mounts here -->
              <p style="color: var(--text-light); font-size: 0.9rem;">
                <% if (stripePk === 'STRIPE_PK') { %>
                  ⚠️ Stripe not configured. Using demo mode — orders will be placed without real payment.
                <% } else { %>
                  Enter your card details below:
                <% } %>
              </p>
            </div>
            <div id="card-errors" style="color: var(--danger); font-size: 0.85rem; margin-bottom: 1rem;"></div>
          </div>
        </div>
      </div>

      <div class="cart-summary">
        <h3>Order Summary</h3>
        <% items.forEach(item => { %>
          <div class="summary-row">
            <span><%= item.name %> ×<%= item.quantity %></span>
            <span>PKR <%= (item.price * item.quantity).toLocaleString() %></span>
          </div>
        <% }); %>
        <div class="summary-row">
          <span>Shipping</span>
          <span style="color: var(--success);">Free</span>
        </div>
        <div class="summary-row total">
          <span>Total</span>
          <span>PKR <%= total.toLocaleString() %></span>
        </div>
        
        <button class="btn btn-gold btn-block btn-lg" style="margin-top: 1.5rem;" onclick="placeOrder()" id="payBtn">
          💳 Pay PKR <%= total.toLocaleString() %>
        </button>
        <p style="text-align: center; font-size: 0.75rem; color: var(--text-muted); margin-top: 0.5rem;">🔒 Secured by Stripe</p>
      </div>
    </div>
  </div>
</div>

<script>
async function placeOrder() {
  const btn = document.getElementById('payBtn');
  const address = document.getElementById('address').value;
  const phone = document.getElementById('phone').value;
  const fullName = document.getElementById('fullName').value;

  if (!address || !phone || !fullName) {
    alert('Please fill in all shipping details.');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Processing...';

  try {
    // Create payment intent
    const piRes = await fetch('/checkout/create-payment-intent', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    const piData = await piRes.json();

    if (piData.error) {
      alert(piData.error);
      btn.disabled = false;
      btn.textContent = '💳 Pay';
      return;
    }

    // Complete order
    const orderRes = await fetch('/checkout/complete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        paymentIntent: piData.clientSecret,
        shippingAddress: fullName + '\n' + address + '\n' + phone
      })
    });
    const orderData = await orderRes.json();

    if (orderData.success) {
      window.location.href = '/checkout/confirmation';
    } else {
      alert(orderData.error || 'Order failed');
      btn.disabled = false;
      btn.textContent = '💳 Pay';
    }
  } catch (err) {
    alert('Payment failed. Please try again.');
    btn.disabled = false;
    btn.textContent = '💳 Pay';
  }
}
</script>
<%- include('../partials/footer') %>

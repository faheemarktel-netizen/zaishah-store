<%- include('../partials/header') %>
<div class="main-content">
  <div class="container" style="max-width: 600px;">
    <div class="card">
      <div class="card-header">🏪 Setup Your Store</div>
      <div class="card-body">
        <div class="alert alert-info">
          <strong>📋 Seller Registration:</strong> One-time fee of PKR 5,000. No monthly charges. Only PKR 50 per order as service fee.
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form method="POST" action="/seller/setup" enctype="multipart/form-data">
          <div class="form-group">
            <label>Store Name *</label>
            <input type="text" name="name" class="form-control" placeholder="e.g., Ali Fashion House" required minlength="3">
          </div>
          <div class="form-group">
            <label>Store Description</label>
            <textarea name="description" class="form-control" placeholder="Describe your store and what you sell..."></textarea>
          </div>
          <div class="form-group">
            <label>Store Logo</label>
            <input type="file" name="logo" class="form-control" accept="image/*">
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg">Create My Store</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

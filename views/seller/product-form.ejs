<%- include('../partials/header') %>
<div class="dashboard">
  <%- include('../partials/seller-sidebar', { active: 'products' }) %>
  <div class="dashboard-content">
    <h2 style="margin-bottom: 1.5rem;"><%= product ? '✏️ Edit Product' : '➕ Add Product' %></h2>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="card" style="max-width: 700px;">
      <div class="card-body">
        <form method="POST" action="<%= product ? '/seller/products/edit/' + product.id : '/seller/products/add' %>" enctype="multipart/form-data">
          <div class="form-group">
            <label>Product Name *</label>
            <input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required>
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea name="description" class="form-control"><%= product ? product.description || '' : '' %></textarea>
          </div>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label>Price (PKR) *</label>
              <input type="number" name="price" class="form-control" value="<%= product ? product.price : '' %>" min="1" step="0.01" required>
            </div>
            <div class="form-group">
              <label>Stock</label>
              <input type="number" name="stock" class="form-control" value="<%= product ? product.stock : 0 %>" min="0">
            </div>
          </div>
          <div class="form-group">
            <label>Category</label>
            <select name="category" class="form-control">
              <option value="">Select category...</option>
              <% ['Fashion', 'Electronics', 'Home & Art', 'Food', 'Beauty', 'Sports', 'Books', 'Other'].forEach(cat => { %>
                <option value="<%= cat %>" <%= product && product.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label>Product Images (up to 5)</label>
            <input type="file" name="images" class="form-control" accept="image/*" multiple>
            <% if (product) { %>
              <% const imgs = JSON.parse(product.images || '[]'); %>
              <% if (imgs.length > 0) { %>
                <div style="margin-top: 0.5rem; display: flex; gap: 0.5rem;">
                  <% imgs.forEach(img => { %>
                    <img src="<%= img %>" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                  <% }); %>
                </div>
              <% } %>
            <% } %>
          </div>
          <% if (product) { %>
            <div class="form-group">
              <label>
                <input type="checkbox" name="active" value="1" <%= product.active ? 'checked' : '' %>> Active (visible to buyers)
              </label>
            </div>
          <% } %>
          <div class="d-flex gap-1">
            <button type="submit" class="btn btn-primary"><%= product ? 'Update Product' : 'Add Product' %></button>
            <a href="/seller/products" class="btn btn-outline">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>

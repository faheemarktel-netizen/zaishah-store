<%- include('../partials/header') %>
<section class="auth-page">
  <div class="container">
    <div class="auth-card">
      <div class="auth-header">
        <h1>🔐 Admin Login</h1>
        <p>Authorized personnel only</p>
      </div>

      <div class="auth-body">
        <% if (typeof error !== 'undefined' && error) { %>
          <div style="background: #ffe0e0; color: var(--danger); padding: 0.8rem; border-radius: var(--radius-sm); margin-bottom: 1rem; text-align: center; font-size: 0.9rem;">
            ❌ <%= error %>
          </div>
        <% } %>
        <form method="POST" action="/auth/dev-login">
          <div style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Email Address</label>
            <input type="email" name="email" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 1rem;" placeholder="Enter admin email..." required>
          </div>
          <div style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Admin Password</label>
            <input type="password" name="adminPassword" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 1rem;" placeholder="Enter admin password..." required>
          </div>
          <button type="submit" class="btn btn-gold btn-block" style="padding: 0.9rem; font-size: 1rem;">Login</button>
        </form>

        <p style="margin-top: 1.5rem; text-align: center;"><a href="/auth/login">← Back to Google Login</a></p>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
